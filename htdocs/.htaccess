# Basic .htaccess for InfinityFree
RewriteEngine On

# Ensure PHP is used for files if needed (usually handled by provider)
# Add index.php / index.html to DirectoryIndex
DirectoryIndex index.html index.php

# Routing - if navigating to /dashboard it might look for dashboard.html
# This allows cleaner URLs or prevents 404s on refresh
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]
